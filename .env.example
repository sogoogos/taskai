# 使用する LLM プロバイダの既定値（claude | openai | gemini）。UI からも切替可能。
LLM_PROVIDER=claude

# Anthropic Claude API キー（https://console.anthropic.com で取得）
ANTHROPIC_API_KEY=sk-ant-...
# 任意: モデル上書き（既定 claude-haiku-4-5）
# ANTHROPIC_MODEL=claude-haiku-4-5

# OpenAI API キー（https://platform.openai.com で取得）
OPENAI_API_KEY=sk-...
# 任意: モデル上書き（既定 gpt-4o-mini）
# OPENAI_MODEL=gpt-4o-mini

# Google Gemini API キー（https://aistudio.google.com で取得・無料枠あり）
GEMINI_API_KEY=...
# 任意: モデル上書き（既定 gemini-2.5-flash）
# GEMINI_MODEL=gemini-2.5-flash

# Google Maps Places API キー（場所/カフェ検索ツール用）
# Google Cloud で「Places API (New)」を有効化し API キーを作成。未設定なら場所検索ツールのみ無効。
GOOGLE_MAPS_API_KEY=AIza...

# Google OAuth クライアント（Google Cloud Console で作成、種別=ウェブアプリケーション）
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx
# 承認済みリダイレクト URI に同じ値を登録すること
GOOGLE_REDIRECT_URI=http://localhost:3000/api/auth/callback

# Cookie セッション署名用の秘密（32文字以上のランダム文字列）
# 生成例: openssl rand -base64 32
SESSION_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# SQLite ファイルの保存先（省略時は ./data/taskai.sqlite）
# DATABASE_PATH=./data/taskai.sqlite
